---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title" style="font-size: 30px;">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>
    <p class="desc">{{ page.subtitle }}</p>
  </header>

  <article>
    {% if page.profile %}
      <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
        {% if page.profile.image %}
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1
      rounded' %}
          {% endif %}
          {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px)
      30vw, 95vw"{% endcapture %}
          {%
            include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
            cache_bust=true
          %}
        {% endif %}
        {% if page.profile.more_info %}
          <div class="more-info">{{ page.profile.more_info }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="clearfix">{{ content }}</div>

    <!-- News -->
    {% if page.news and site.announcements.enabled %}
      <h2 style="margin-top: 25px">
        <a>News</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Latest posts -->
    {% if site.latest_posts.enabled %}
      <h2 style="margin-top: 25px">
        <a>Latest Posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2 style="margin-top: 25px; margin-bottom: -15px">
        <a>Selected Publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    <!-- Selected Projects -->
    {% if page.selected_projects %}
      <h2 style="margin-top: 25px; margin-bottom: 10px">
        <a>Selected Projects</a>
      </h2>
      <div class="row">
        <div class="col-sm-6 mb-3">
          <div class="card h-100">
            <div class="text-center p-2">
              <img src="{{ '/assets/img/Manipulator.gif' | relative_url }}" alt="Manipulator" loading="lazy" style="max-height: 1000px;">
            </div>
            <div class="card-body">
              <h5 class="card-title">Robotic Manipulator Control</h5>
              <p class="card-text" style="font-size: 0.85rem;">
                Trajectory planning and control of a multi-DOF robotic manipulator with inverse kinematics and motion planning.
              </p>
            </div>
          </div>
        </div>
        <div class="col-sm-6 mb-3">
          <div class="card h-100">
            <div class="text-center p-2">
              <img src="{{ '/assets/img/Hopper.gif' | relative_url }}" alt="Hopper Robot" loading="lazy" style="max-height: 300px;">
            </div>
            <div class="card-body">
              <h5 class="card-title">Hopper Robot</h5>
              <p class="card-text" style="font-size: 0.85rem;">
                3D hopper simulation in PyBullet with Raibert, PID, and LQR controllers for stable locomotion on uneven terrain.
              </p>
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    <!-- Undergraduate Projects -->
    {% if page.undergrad_projects %}
      <h2 style="margin-top: 25px; margin-bottom: 10px">
        <a>Undergraduate Projects</a>
      </h2>
      <p style="font-size: 0.9rem; margin-bottom: 12px;">
        Earlier hands-on work at AUST shaped my foundation in robot design, embedded sensing, localization, actuation, and manufacturable CAD.
      </p>
      <div class="row">
        <div class="col-lg-6 col-md-12 mb-3">
          <div class="card h-100">
            <div class="p-2">
              <div class="row no-gutters">
                <div class="col-6 pr-1">
                  <img
                    src="{{ '/assets/img/undergrad_wheeled_robot_design_2018.png' | relative_url }}"
                    alt="Four-wheeled robot CAD design"
                    loading="lazy"
                    class="rounded z-depth-1"
                    style="height: 190px; width: 100%; object-fit: contain; background: #f8f9fa;"
                  >
                </div>
                <div class="col-6 pl-1">
                  <img
                    src="{{ '/assets/img/undergrad_wheeled_robot_prototype_2018.jpg' | relative_url }}"
                    alt="Four-wheeled robot prototype"
                    loading="lazy"
                    class="rounded z-depth-1"
                    style="height: 190px; width: 100%; object-fit: cover;"
                  >
                </div>
              </div>
              <div class="d-flex justify-content-between mt-1 text-muted" style="font-size: 0.72rem;">
                <span>CAD design</span>
                <span>Prototype</span>
              </div>
            </div>
            <div class="card-body">
              <h5 class="card-title">Four-Wheeled Robot Design and Control</h5>
              <p class="card-text" style="font-size: 0.85rem;">
                Sept. 2017 - Nov. 2018, with Prof. Chengjun Wang. Developed a Mecanum-wheel robot platform with STM32F4 sensing, gyroscope/encoder fusion, localization, pneumatic transmission, and manipulator integration.
              </p>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
          <div class="card h-100">
            <div class="text-center p-2">
              <img
                src="{{ '/assets/img/undergrad_hand_design_2017.jpg' | relative_url }}"
                alt="Flexible robotic hand prototype"
                loading="lazy"
                class="rounded z-depth-1"
                style="height: 190px; width: 100%; object-fit: cover; object-position: center 35%;"
              >
            </div>
            <div class="card-body">
              <h5 class="card-title">Flexible Robotic Hand Prototype</h5>
              <p class="card-text" style="font-size: 0.85rem;">
                Built early manipulation hardware with flexible sensing modules and compact electromechanical integration for hands-on robotics experiments.
              </p>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
          <div class="card h-100">
            <div class="text-center p-2">
              <img
                src="{{ '/assets/img/undergrad_injection_mold_design_2019.jpg' | relative_url }}"
                alt="Injection mold CAD design"
                loading="lazy"
                class="rounded z-depth-1"
                style="height: 190px; width: 100%; object-fit: cover;"
              >
            </div>
            <div class="card-body">
              <h5 class="card-title">Injection Mold Design</h5>
              <p class="card-text" style="font-size: 0.85rem;">
                Practiced manufacturability-aware CAD through mold assembly design, mechanism constraints, spring-loaded components, and parting-line considerations.
              </p>
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% include social.liquid %}</div>

        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}

    {% if site.newsletter.enabled and site.footer_fixed %}
      {% include scripts/newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
